{
    "name": "ocr-splitter-backend",
    "version": "1.0.0",
    "description": "Backend API for OCR Splitter - Sistema de división de gastos con reconocimiento óptico",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "type-check": "tsc --noEmit"
    },
    "keywords": [
        "ocr",
        "expense-splitting",
        "firebase",
        "google-vision"
    ],
    "author": "Sebastian Palacios Vera",
    "license": "MIT",
    "dependencies": {
        "@google-cloud/vision": "^4.3.2",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "firebase-admin": "^12.1.0",
        "multer": "^1.4.5-lts.1",
        "uuid": "^10.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.12.12",
        "@types/uuid": "^10.0.0",
        "tsx": "^4.10.5",
        "typescript": "^5.4.5"
    }
}